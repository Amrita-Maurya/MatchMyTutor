# MatchMyTutor — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env        (Mac/Linux)
#   copy .env.example .env      (Windows)
#
# .env is listed in .gitignore — never commit it to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ── Django core ───────────────────────────────────────────────────────────────

# Required. Generate a new one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to False in production. True enables detailed error pages.
DEBUG=True

# Comma-separated list of allowed hostnames.
# Examples: localhost,127.0.0.1,.yourdomain.com
# Leave as * for local development only.
ALLOWED_HOSTS=*


# ── Database ──────────────────────────────────────────────────────────────────

# Leave blank to use SQLite (auto-created as db.sqlite3, good for local dev).
# Set to a PostgreSQL URL for production:
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# If you prefer individual PostgreSQL variables instead of DATABASE_URL:
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=matchmytutor
# PGUSER=postgres
# PGPASSWORD=yourpassword


# ── Email ─────────────────────────────────────────────────────────────────────

# Default (console): prints emails to the terminal — good for local dev.
# For real email: set to django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Only needed when EMAIL_BACKEND is smtp:
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# The "From" address shown in outgoing emails.
DEFAULT_FROM_EMAIL=MatchMyTutor <noreply@matchmytutor.app>


# ── Optional: time zone ───────────────────────────────────────────────────────

# Default is Asia/Kolkata. Change to your local zone:
# TIME_ZONE=UTC
# TIME_ZONE=America/New_York
# TIME_ZONE=Europe/London
